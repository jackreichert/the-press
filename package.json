{
  "name": "thepress",
  "version": "0.0.1",
  "description": "The Press — a browser-based daily word puzzle game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dict:build": "tsx scripts/process-dict.ts",
    "puzzle:generate": "tsx scripts/generate-puzzles.ts",
    "puzzle:check": "tsx scripts/check-puzzles.ts",
    "pipeline": "npm run dict:build && npm run puzzle:generate"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
